algoritmo "Gabriel"
// Função :
// Autor :
// Data : 12/05/2026
// Seção de Declarações 
var
n1,n2,n3,n4,media : Real
Nome: Caractere
inicio
// Seção de Comandos
Leia (Nome,n1,n2,n3,n4)
media <- ( n1 + n2 + n3 + n4 ) / 4
Escreval("Média de ", Nome, " é de ", media)

se media > 7 entao
   escreval("Aprovado")
senao
    escreval("Reprovado")
fimse

fimalgoritmo

